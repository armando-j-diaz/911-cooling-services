---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import WhoWeAre from '../components/WhoWeAre.astro';
import GoogleReviews from '../components/GoogleReviews.astro';
import LeadForm from '../components/LeadForm.astro';
import ServiceAreas from '../components/ServiceAreas.astro';
import Footer from '../components/Footer.astro';
import '../styles/sections-dark.css';
---

<Layout>
  <Header />
  <main>
    <Hero />
    <div class="site-dark-band">
      <GoogleReviews showGoogleLink />
      <WhoWeAre />
      <LeadForm />
      <ServiceAreas />
    </div>
  </main>
  <Footer />
</Layout>
