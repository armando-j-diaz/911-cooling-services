---
import '../styles/google-reviews.css';
import { site } from '../data/site';

interface Props {
  showGoogleLink?: boolean;
  showEditNote?: boolean;
}

const { showGoogleLink = false, showEditNote = false } = Astro.props;
const r = site.reviews;

function initials(name: string): string {
  return name
    .split(' ')
    .map((n) => n[0])
    .join('')
    .slice(0, 2)
    .toUpperCase();
}
---

<section class="section-block py-14 sm:py-20" aria-labelledby="reviews-heading">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div>
      <div class="flex items-center gap-3">
        <div class="section-accent-line shrink-0" aria-hidden="true">
          <span></span>
          <span></span>
        </div>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-white/90">{r.prehead}</p>
      </div>
      <h2
        id="reviews-heading"
        class="mt-4 text-2xl font-extrabold uppercase leading-tight tracking-tight sm:text-3xl lg:text-4xl"
      >
        {r.headline}
      </h2>
    </div>

    <div class="reviews-carousel-shell mt-8">
      <div class="reviews-carousel-row">
        <button
          type="button"
          class="reviews-nav reviews-nav--prev"
          data-reviews-prev
          aria-label="Previous reviews"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-5 w-5" aria-hidden="true">
            <path stroke-linecap="square" d="M15 6l-6 6 6 6" />
          </svg>
        </button>

        <div id="reviews-carousel" class="reviews-carousel min-w-0 flex-1" aria-roledescription="carousel">
          <div id="reviews-track" class="reviews-track">
        {
          r.items.map((review, i) => (
            <div class="reviews-slide" role="group" aria-label={`Review ${i + 1} of ${r.items.length}`}>
              <article
                class:list={[
                  'flex h-full flex-col border bg-[#1a222d] p-5 transition-colors duration-300',
                  i === 1 ? 'border-emergency/60' : 'border-white/10',
                ]}
              >
                <div class="flex items-start justify-between gap-2">
                  <div class="flex items-center gap-3">
                    <div
                      class="flex h-10 w-10 shrink-0 items-center justify-center bg-navy text-xs font-bold text-white"
                      aria-hidden="true"
                    >
                      {initials(review.name)}
                    </div>
                    <div>
                      <p class="text-sm font-bold text-white">{review.name}</p>
                      <p class="text-xs text-white/45">{review.time}</p>
                    </div>
                  </div>
                  <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" aria-label="Google review">
                    <path
                      fill="#4285F4"
                      d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                    />
                    <path
                      fill="#34A853"
                      d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                    />
                    <path
                      fill="#FBBC05"
                      d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                    />
                    <path
                      fill="#EA4335"
                      d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                    />
                  </svg>
                </div>

                <div class="mt-3 flex items-center gap-1.5" aria-label="5 out of 5 stars">
                  {[1, 2, 3, 4, 5].map(() => (
                    <svg
                      class="h-4 w-4 text-amber-400"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                  <span
                    class="ml-1 flex h-4 w-4 items-center justify-center bg-[#4285F4] text-[10px] font-bold text-white"
                    title="Verified review"
                    aria-hidden="true"
                  >
                    ✓
                  </span>
                </div>

                <p class="review-text is-clamped mt-3 flex-1 text-sm leading-relaxed text-white/70">
                  {review.text}
                </p>
                <button
                  type="button"
                  class="review-expand-btn mt-3 self-start text-xs text-white/40 hover:text-white/70"
                  data-review-expand
                  aria-expanded="false"
                >
                  Read more
                </button>
              </article>
            </div>
          ))
        }
          </div>
        </div>

        <button
          type="button"
          class="reviews-nav reviews-nav--next"
          data-reviews-next
          aria-label="Next reviews"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-5 w-5" aria-hidden="true">
            <path stroke-linecap="square" d="M9 6l6 6-6 6" />
          </svg>
        </button>
      </div>

      <div class="reviews-progress" aria-hidden="true">
        <div id="reviews-progress-bar" class="reviews-progress-bar" style="width: 16.67%"></div>
      </div>
    </div>

    {
      showGoogleLink && (
        <div class="mt-8 flex justify-center">
          <a
            href={site.googleBusinessUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="gradient-emergency inline-flex min-h-12 w-full max-w-md items-center justify-center px-6 py-3 text-sm font-bold uppercase tracking-wide text-white shadow-cta transition hover:opacity-95 sm:w-auto sm:min-w-[18rem]"
          >
            See More Google Reviews
          </a>
        </div>
      )
    }

    {
      showEditNote && (
        <p class="mt-6 text-center text-xs text-white/35">
          Swipe or wait — reviews rotate every 10 seconds. Edit copy in{' '}
          <code class="text-white/50">src/data/site.ts</code>.
        </p>
      )
    }
  </div>
</section>

<script>
  import '../scripts/reviews-carousel.ts';
  import '../scripts/reviews-expand.ts';
</script>
