---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<div class="flex items-center gap-3">
  <div class="section-accent-line shrink-0" aria-hidden="true">
    <span></span>
    <span></span>
  </div>
  <p class="text-xs font-bold uppercase tracking-[0.2em] text-white/90">{label}</p>
</div>
