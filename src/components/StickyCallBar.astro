---
import { site } from '../data/site';
---

<div
  class="fixed bottom-0 left-0 right-0 z-50 grid grid-cols-2 gap-2 border-t border-navy/10 bg-white/95 p-2 backdrop-blur-md md:hidden"
  role="complementary"
  aria-label="Quick actions"
>
  <a
    href={`tel:${site.phoneTel}`}
    class="header-phone-btn flex min-h-11 items-center justify-center gap-1.5 text-sm font-bold uppercase tracking-wide"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
      <path
        fill-rule="evenodd"
        d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.716 22.5 1.5 15.284 1.5 6.75V4.5z"
        clip-rule="evenodd"></path>
    </svg>
    Call
  </a>
  <a
    href="#quote"
    class="gradient-emergency flex min-h-11 items-center justify-center text-sm font-bold uppercase tracking-wide text-white shadow-cta"
  >
    Get Quote
  </a>
</div>
