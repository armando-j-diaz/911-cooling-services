---
import SectionLabel from '../SectionLabel.astro';
import { site } from '../../data/site';

const f = site.about.faq;
---

<section class="section-block py-14 sm:py-20">
  <div class="mx-auto max-w-6xl px-4 text-left sm:px-6">
    <SectionLabel label={f.prehead} />

    <h2 class="mt-4 text-2xl font-extrabold uppercase leading-tight tracking-tight sm:text-3xl">
      {f.headline}
    </h2>

    <p class="mt-4 text-white/75">{f.intro}</p>

    <div class="mt-10 border border-white/20">
      {
        f.items.map((item, i) => (
          <details
            class="faq-item group border-b border-white/20 last:border-b-0"
            open={i === 0}
          >
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-4 py-5 font-bold uppercase tracking-wide text-white hover:bg-white/5 [&::-webkit-details-marker]:hidden">
              <span class="text-sm sm:text-base">{item.question}</span>
              <span class="shrink-0 text-xl leading-none text-white/70" aria-hidden="true">
                <span class="faq-icon-plus">+</span>
                <span class="faq-icon-minus">−</span>
              </span>
            </summary>
            <div class="border-t border-white/10 bg-white/5 px-4 py-4 text-sm leading-relaxed text-white/80 sm:text-base">
              {item.answer}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
