---
import '../../styles/about-page.css';
import SectionLabel from '../SectionLabel.astro';
import { site } from '../../data/site';

const s = site.about.standFor;
---

<section class="section-block relative overflow-hidden py-14 sm:py-20">
  <div
    class="absolute inset-0 bg-cover bg-center"
    style="background-image: url('/images/hero/02.png');"
    aria-hidden="true"
  >
  </div>
  <div class="about-stand-for__overlay" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
    <SectionLabel label={s.prehead} />

    <h2 class="mt-4 text-2xl font-extrabold uppercase leading-tight tracking-tight sm:text-3xl lg:text-4xl">
      {s.headline}
    </h2>

    <p class="mt-4 max-w-2xl text-white/85">{s.intro}</p>

    <ul class="mt-10 space-y-8">
      {
        s.pillars.map((pillar) => (
          <li class="flex gap-4 sm:gap-6">
            <span
              class="flex h-14 w-14 shrink-0 items-center justify-center border-2 border-emergency bg-emergency/20 text-xl font-bold text-emergency-light"
              aria-hidden="true"
            >
              ✓
            </span>
            <div>
              <h3 class="text-lg font-bold uppercase tracking-wide text-white">{pillar.title}</h3>
              <p class="mt-2 leading-relaxed text-white/80">{pillar.body}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
