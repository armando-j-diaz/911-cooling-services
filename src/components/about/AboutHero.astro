---
import '../../styles/about-page.css';
import { site } from '../../data/site';
import { basePath } from '../../lib/paths';

const h = site.about.hero;
---

<section class="about-hero text-white">
  <div class="about-hero__bg" style={`background-image: url('${h.image}')`} aria-hidden="true"></div>
  <div class="about-hero__overlay" aria-hidden="true"></div>

  <div class="relative mx-auto w-full max-w-6xl px-4 pb-16 pt-28 sm:px-6 sm:pb-20 sm:pt-32 lg:pt-36">
    <div class="max-w-2xl">
      <div class="flex items-center gap-3">
        <div class="section-accent-line shrink-0" aria-hidden="true">
          <span></span>
          <span></span>
        </div>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-white/90">
          <a href={basePath()} class="transition hover:text-white">Home</a>
          <span class="text-white/50"> / </span>
          <span>About Us</span>
        </p>
      </div>

      <h1 class="mt-6 text-4xl font-extrabold uppercase leading-tight tracking-tight sm:text-5xl lg:text-6xl">
        {h.headline}
      </h1>
    </div>
  </div>
</section>
