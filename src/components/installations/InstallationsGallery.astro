---
import SectionLabel from '../SectionLabel.astro';
import { site } from '../../data/site';

const { galleryImages } = site.installations;
---

<section class="section-block py-14 sm:py-20" aria-labelledby="gallery-heading">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionLabel label="Project Gallery" />

    <h2 id="gallery-heading" class="mt-4 text-2xl font-extrabold uppercase tracking-tight sm:text-3xl">
      Before &amp; After — Our Work
    </h2>

    <ul class="mt-10 grid grid-cols-1 gap-6 pb-6 sm:grid-cols-2 installations-gallery-grid">
      {
        galleryImages.map((image, index) => (
          <>
            <li class="group overflow-hidden border border-white/10 bg-[#121820]">
              <img
                src={image.src}
                alt={image.alt}
                class="aspect-[16/10] w-full object-cover object-center transition duration-300 group-hover:scale-[1.01]"
                loading="lazy"
                width={600}
                height={450}
              />
            </li>
            {index === 1 && (
              <li
                class="installations-gallery-sentinel col-span-full !m-0 !h-px !min-h-0 list-none overflow-hidden border-0 p-0"
                data-installations-sentinel
                aria-hidden="true"
              />
            )}
          </>
        ))
      }
    </ul>
  </div>
</section>
