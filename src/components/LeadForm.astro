---
import { site } from '../data/site';
---

<section id="quote" class="section-block py-14 sm:py-20" aria-labelledby="quote-heading">
  <div class="mx-auto max-w-2xl px-4 sm:px-6">
    <div class="text-center">
      <h2 id="quote-heading" class="text-3xl font-extrabold uppercase tracking-tight sm:text-4xl">
        Get a Free Quote
      </h2>
      <p class="mt-3 text-white/70">
        Tell us about your system. Prefer to talk now?
        <a href={`tel:${site.phoneTel}`} class="text-phone font-bold hover:underline">
          {site.phone}
        </a>
      </p>
    </div>

    <div
      id="form-success"
      class="mt-8 hidden border-2 border-emergency/40 bg-white/10 p-8 text-center"
      role="status"
    >
      <p class="text-xl font-bold text-white">Request received!</p>
      <p class="mt-2 text-white/80">
        A 911 Cooling technician will contact you shortly. For emergencies, call
        <a href={`tel:${site.phoneTel}`} class="text-phone font-bold hover:underline">
          {site.phone}
        </a>
        now.
      </p>
    </div>

    <div
      id="form-error"
      class="mt-8 hidden border-2 border-red-400/40 bg-red-950/30 p-6 text-center"
      role="alert"
    >
      <p data-error-msg class="font-medium text-white"></p>
      <a
        data-call-link
        href={`tel:${site.phoneTel}`}
        class="mt-4 inline-flex min-h-12 items-center justify-center gradient-emergency px-6 py-3 font-bold text-white shadow-cta"
      >
        Call {site.phone} Now
      </a>
    </div>

    <form
      id="lead-form"
      class="mt-8 space-y-5 border border-white/10 bg-white p-6 shadow-card sm:p-8"
      novalidate
    >
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="first_name" class="mb-1.5 block text-sm font-semibold text-navy">
            First name <span class="text-emergency">*</span>
          </label>
          <input
            type="text"
            id="first_name"
            name="first_name"
            required
            autocomplete="given-name"
            class="w-full min-h-12 border border-navy/15 bg-white px-4 py-3 text-navy outline-none transition focus:border-emergency focus:ring-2 focus:ring-emergency/20"
            placeholder="John"
          />
        </div>
        <div>
          <label for="last_name" class="mb-1.5 block text-sm font-semibold text-navy">
            Last name <span class="text-emergency">*</span>
          </label>
          <input
            type="text"
            id="last_name"
            name="last_name"
            required
            autocomplete="family-name"
            class="w-full min-h-12 border border-navy/15 bg-white px-4 py-3 text-navy outline-none transition focus:border-emergency focus:ring-2 focus:ring-emergency/20"
            placeholder="Smith"
          />
        </div>
      </div>

      <div>
        <label for="phone" class="mb-1.5 block text-sm font-semibold text-navy">
          Phone <span class="text-emergency">*</span>
        </label>
        <input
          type="tel"
          id="phone"
          name="phone"
          required
          autocomplete="tel"
          class="w-full min-h-12 border border-navy/15 bg-white px-4 py-3 text-navy outline-none transition focus:border-emergency focus:ring-2 focus:ring-emergency/20"
          placeholder="(305) 449-9924"
        />
      </div>

      <div>
        <label for="email" class="mb-1.5 block text-sm font-semibold text-navy">
          Email <span class="text-emergency">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          class="w-full min-h-12 border border-navy/15 bg-white px-4 py-3 text-navy outline-none transition focus:border-emergency focus:ring-2 focus:ring-emergency/20"
          placeholder="you@email.com"
        />
      </div>

      <div>
        <label for="details" class="mb-1.5 block text-sm font-semibold text-navy">
          Unit / issue details <span class="text-emergency">*</span>
        </label>
        <textarea
          id="details"
          name="details"
          required
          rows="4"
          class="w-full border border-navy/15 bg-white px-4 py-3 text-navy outline-none transition focus:border-emergency focus:ring-2 focus:ring-emergency/20"
          placeholder="e.g. AC not cooling, unit is 12 years old, making loud noise…"></textarea>
      </div>

      <p id="form-status" class="sr-only" aria-live="polite"></p>

      <button
        type="submit"
        id="form-submit"
        class="gradient-emergency w-full min-h-14 px-6 py-4 text-lg font-bold uppercase tracking-wide text-white shadow-cta transition hover:opacity-95 disabled:cursor-not-allowed disabled:opacity-60"
      >
        Get My Free Quote
      </button>

      <p class="text-center text-xs text-navy-light/60">
        By submitting, you agree to be contacted about your HVAC service request.
      </p>
    </form>
  </div>
</section>

<script>
  import '../scripts/form-submit.ts';
</script>
