---
import '../styles/hero-banner.css';
import '../styles/who-we-are-photos.css';
import { site } from '../data/site';

const w = site.whoWeAre;
const slideshowJson = JSON.stringify(
  w.slideshowImages?.length ? w.slideshowImages : [w.photoTop, w.photoBottom],
);
---

<div class="relative z-0 pl-4 sm:pl-6">
  <div
    class="who-we-are-accent-bar absolute left-0 top-10 z-10 flex h-28 w-2 flex-col sm:top-12 sm:h-36"
    aria-hidden="true"
  >
    <span class="flex-1"></span>
    <span class="flex-1"></span>
    <span class="flex-1"></span>
  </div>

  <div class="who-we-are-frame relative ml-3 border-t-2 border-r-2 pl-6 pt-6 pr-4 pb-4 sm:ml-4 sm:pl-10 sm:pt-10 sm:pr-6 sm:pb-6">
    <div
      class="hero-banner hero-banner--card"
      data-hero-morph
      data-images={slideshowJson}
      role="img"
      aria-label="911 Cooling technicians at work"
    >
      <div class="hero-slides" data-hero-slides aria-hidden="true"></div>
    </div>
    <img
      src={w.photoBottom}
      alt="911 Cooling service team"
      class="who-we-are-photo-secondary -mt-12 ml-6 w-[88%] border-4 object-cover sm:-mt-20 sm:ml-12 sm:w-[85%]"
      width={500}
      height={320}
      loading="lazy"
    />
  </div>
</div>

<script>
  import '../scripts/hero-morph.ts';
</script>
