---
import { site } from '../data/site';

const badges = [
  { icon: '✓', label: 'Florida Licensed HVAC Contractor' },
  { icon: '✓', label: 'Fully Insured' },
  { icon: '✓', label: '24/7 Emergency Dispatch' },
  { icon: '✓', label: 'Upfront Pricing — No Hidden Fees' },
];
---

<section class="section-block py-12 sm:py-16" aria-labelledby="trust-heading">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <h2 id="trust-heading" class="text-center text-2xl font-extrabold uppercase tracking-tight sm:text-3xl">
      Why South Florida Homeowners Trust 911 Cooling
    </h2>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        badges.map((badge) => (
          <div class="flex flex-col items-center border border-white/10 bg-white/5 p-6 text-center">
            <span
              class="flex h-10 w-10 items-center justify-center gradient-emergency text-lg font-bold text-white"
              aria-hidden="true"
            >
              {badge.icon}
            </span>
            <p class="mt-3 text-sm font-semibold leading-snug text-white/90">{badge.label}</p>
          </div>
        ))
      }
    </div>

    <p class="mt-8 text-center text-sm font-medium text-white/50">
      {site.license}
    </p>
  </div>
</section>
