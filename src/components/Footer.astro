---
import { site } from '../data/site';
import { basePath } from '../lib/paths';

const year = new Date().getFullYear();
---

<footer class="bg-[#0c1219] py-10 text-white">
  <div class="mx-auto max-w-6xl px-4 text-center sm:px-6">
    <img src={basePath('logo.png?v=2')} alt="911 Cooling" class="mx-auto h-16 w-auto max-w-xs opacity-90 sm:h-20" width="640" height="377" />

    <p class="mt-4 text-sm text-ice">{site.tagline}</p>

    <a
      href={`tel:${site.phoneTel}`}
      class="mt-4 inline-block text-2xl font-extrabold text-emergency-light transition hover:text-white"
    >
      {site.phone}
    </a>

    <p class="mt-4 text-xs text-ice/80">{site.license}</p>

    <p class="mt-6 text-xs text-ice/60">
      © {year} {site.name}. All rights reserved.
    </p>
  </div>
</footer>
