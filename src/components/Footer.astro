---
import { site } from '../data/site';
import { basePath } from '../lib/paths';

const year = new Date().getFullYear();
---

<footer class="bg-[#05080e] py-10 text-white">
  <div class="mx-auto max-w-6xl px-4 text-center sm:px-6">
    <img
      src={basePath('logo.png?v=4')}
      alt="911 Cooling"
      class="mx-auto h-40 w-auto max-w-[min(90vw,22rem)] opacity-95 sm:h-48 sm:max-w-[26rem]"
      width="1024"
      height="1024"
    />

    <p class="mt-4 text-sm text-ice">{site.tagline}</p>

    <a
      href={`tel:${site.phoneTel}`}
      class="text-phone mt-4 inline-block text-2xl font-extrabold transition"
    >
      {site.phone}
    </a>

    <p class="mt-4 text-xs text-ice/80">{site.license}</p>

    <p class="mt-6 text-xs text-ice/60">
      © {year} {site.name}. All rights reserved.
    </p>
  </div>
</footer>
